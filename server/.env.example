# Copy this file to ".env" and fill in your values. Never commit the real .env.

# Your OpenRouter API key — get one at https://openrouter.ai/keys
# This stays on the server and is never sent to the browser.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port for the local server (open http://localhost:PORT)
PORT=3000

# The ONLY directory the CODE agent may read/write. Used from Phase 2 onward.
# Relative paths resolve against the server/ folder. An absolute path is fine too.
WORKSPACE_DIR=./workspace

# SQLite database file (tasks, checkpoints, usage history).
# Relative paths resolve against the server/ folder. An absolute path is fine too.
# Created automatically on first run.
DATA_DIR=./.data/chatty.db
